<Page x:Class="Test942.Pages.PartnersAddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Test942.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="500"
      Title="PartnersAddEditPage">

    <Grid Background="White">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Наименование" />
                <TextBox Text="{Binding NamePartner}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Тип" />
                <ComboBox x:Name="TypeCb" SelectedItem="{Binding TypeOfBusiness.NameBusiness}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Юридический адресс" />
                <TextBox Text="{Binding UrAdress}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="ИНН" />
                <TextBox Text="{Binding INN}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Фамилия директора" />
                <TextBox Text="{Binding SurnameDirector}"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Имя директора" />
                <TextBox Text="{Binding NameDirector}"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Отчество директора" />
                <TextBox Text="{Binding PatronumicDirector}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Телефон" />
                <TextBox Text="{Binding Phone}"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="EMAIL" />
                <TextBox Text="{Binding Email}"/>
            </StackPanel>
            
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock Text="Рейтинг" />
                <TextBox Text="{Binding Raiting}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="SaveBtn" Content="Сохранить" 
                        Background="#355CBD" Foreground="White"
                        Width="100" Height="25" FontSize="14" Margin=" 0 0 8 0"
                        Click="SaveBtn_Click"/>
                <Button x:Name="BackBtn" Content="Назад" 
                        Background="White" Foreground="#355CBD"
                        Width="100" Height="25" FontSize="14"  
                        Click="BackBtn_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
