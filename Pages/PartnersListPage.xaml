<Page x:Class="Test942.Pages.PartnersListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Test942.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartnersListPage">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10" HorizontalAlignment="Center">
            <TextBlock Text="ПОИСК:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" FontWeight="Bold"/>
            <TextBox x:Name="SearchTextBox" Width="250" Height="30" Margin="0,0,20,0" VerticalAlignment="Center" 
                     TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Text="СОРТИРОВКА:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" FontWeight="Bold"/>
            <ComboBox x:Name="SortComboBox" Width="180" Height="30" VerticalAlignment="Center" 
                      SelectionChanged="SortComboBox_SelectionChanged">
                <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                <ComboBoxItem Content="По названию (A-Z)"/>
                <ComboBoxItem Content="По названию (Z-A)"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2">
            <Button x:Name="AddBtn" Content="Добавить"
                Width="100" Height="30" 
                FontSize="14" HorizontalAlignment="Center" Margin=" 0 0 10 0"
                    Background="#355CBD" Foreground="White"
                    Click="AddBtn_Click"/>
            <Button x:Name="EditBtn" Content="Редактировать"
                 Width="100" Height="30" 
                 FontSize="14" HorizontalAlignment="Center"
                    Background="White" Foreground="#355CBD"
                    Click="EditBtn_Click" Margin="0 0 10 0"/>
            <Button Content="Удалить" Name="btnDelete" Margin="0 0 10 0"
                    Width="100" Height="30" Click="btnDelete_Click"
                    Background="#FF4444" Foreground="White" Padding="5"/>
            <Button Content="История продаж" Name="btnHistory" 
                    Width="130" Height="30" Click="btnHistory_Click"
                    Background="#355CBD" Foreground="White" />
        </StackPanel>
        <ListView x:Name="PartnersLW" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="10">
                        <Grid Width="700" Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" >
                                <TextBlock Text="{Binding TypeOfBusiness.NameBusiness}"/>
                                <TextBlock Text=" | "/>
                                <TextBlock Text="{Binding NamePartner}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" >
                                <TextBlock Text="{Binding SurnameDirector}"/>
                                <TextBlock Text="{Binding NameDirector}"/>
                                <TextBlock Text="{Binding PatronumicDirector}"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{Binding Phone}"/>
                            <TextBlock Grid.Row="3" Text="{Binding Raiting}"/>

                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SizeDiscount}" FontSize="18" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
